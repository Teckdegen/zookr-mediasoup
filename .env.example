# The public IP of this Railway service (Railway sets this automatically)
# Set this to your Railway service's public IP or domain
ANNOUNCED_IP=your.railway.service.ip

# Port (Railway sets PORT automatically)
PORT=3001

# TURN server credentials (optional — open relay used as fallback)
TURN_URL=turn:your-turn-server.metered.live:80
TURN_USERNAME=your_turn_username
TURN_CREDENTIAL=your_turn_credential
